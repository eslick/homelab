services:
  vllm:
    image: "vllm/vllm-openai:gemma4"
    container_name: vllm
    ports:
      - "127.0.0.1:{{ vllm_port }}:8000"
    environment:
      - HF_TOKEN={{ hugging_face_token }}
      - HUGGING_FACE_HUB_TOKEN={{ hugging_face_token }}
    command: >
      --model {{ vllm_model_id }}
      --served-model-name gemma-4
      --tensor-parallel-size 1
      --gpu-memory-utilization {{ vllm_gpu_memory_fraction }}
      --max-model-len {{ vllm_max_model_len }}
      --dtype auto
      --kv-cache-dtype auto
      --enable-prefix-caching
      --generation-config vllm
      --enable-auto-tool-choice
      --tool-call-parser gemma4
      --trust-remote-code
      --port 8000
    volumes:
      - vllm-models:/root/.cache/huggingface
    networks:
      - {{ docker_network }}
    shm_size: "1g"
    restart: unless-stopped
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: 1
              capabilities: [gpu]
    healthcheck:
      test: ["CMD", "curl", "-sf", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 10
      start_period: 300s

volumes:
  vllm-models:

networks:
  {{ docker_network }}:
    external: true
