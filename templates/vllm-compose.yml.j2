services:
  vllm:
    image: "vllm/vllm-openai:gemma4"
    container_name: vllm
    ports:
      - "127.0.0.1:{{ vllm_port }}:8000"
    environment:
      - HF_TOKEN={{ hugging_face_token }}
      - HUGGING_FACE_HUB_TOKEN={{ hugging_face_token }}
      - VLLM_ATTENTION_BACKEND=FLASHINFER
    command: >
      --model {{ vllm_model_id }}
      --served-model-name {{ vllm_served_model_name }}
      --tensor-parallel-size {{ vllm_tensor_parallel_size }}
      --gpu-memory-utilization {{ vllm_gpu_memory_fraction }}
      --max-model-len {{ vllm_max_model_len }}
      --dtype auto
      --kv-cache-dtype {{ vllm_kv_cache_dtype }}
      --enable-prefix-caching
      --enable-chunked-prefill
      --trust-remote-code
      --port 8000
      {{ vllm_extra_args | default('') }}
    volumes:
      - vllm-models:/root/.cache/huggingface
    networks:
      - {{ docker_network }}
    shm_size: "4g"
    restart: unless-stopped
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]
    healthcheck:
      test: ["CMD", "curl", "-sf", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 10
      start_period: 300s

volumes:
  vllm-models:

networks:
  {{ docker_network }}:
    external: true
