#!/usr/bin/env python3
# Managed by Ansible — do not edit directly
# See playbooks/obsidian-sync.yml
#
# Syncs Obsidian vault from CouchDB (Self-hosted LiveSync) to the filesystem.
# Runs as a systemd service (live _changes watcher) with a cron fallback.

import json
import os
import sys
import time
import logging
import argparse
import requests
from pathlib import Path
from urllib.parse import quote

COUCH_URL  = "http://{{ couchdb_admin_user }}:{{ couchdb_admin_password }}@localhost:{{ couchdb_port }}"
DB         = "{{ couchdb_database }}"
VAULT_PATH = Path("{{ vault_path }}")

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s %(levelname)s %(message)s",
    stream=sys.stdout,
)
log = logging.getLogger("obsidian-sync")


# ---------------------------------------------------------------------------
# CouchDB helpers
# ---------------------------------------------------------------------------

def db_url(path=""):
    return f"{COUCH_URL}/{DB}{path}"


def get_doc(doc_id):
    r = requests.get(db_url(f"/{quote(doc_id, safe='')}"), timeout=10)
    r.raise_for_status()
    return r.json()


def get_all_plain_docs():
    """Return all plain (file-metadata) docs with their content."""
    params = {
        "include_docs": "true",
    }
    r = requests.get(db_url("/_all_docs"), params=params, timeout=60)
    r.raise_for_status()
    return [row["doc"] for row in r.json()["rows"]
            if row["doc"].get("type") == "plain"]


# ---------------------------------------------------------------------------
# File reconstruction
# ---------------------------------------------------------------------------

def fetch_content(plain_doc):
    """Concatenate leaf chunks in order to reconstruct file content."""
    parts = []
    for child_id in plain_doc.get("children", []):
        leaf = get_doc(child_id)
        parts.append(leaf.get("data", ""))
    return "".join(parts)


def write_file(path_str, content):
    dest = VAULT_PATH / path_str
    dest.parent.mkdir(parents=True, exist_ok=True)
    existing = dest.read_text(encoding="utf-8") if dest.exists() else None
    if existing == content:
        return False  # no change
    dest.write_text(content, encoding="utf-8")
    log.info("wrote %s (%d bytes)", dest, len(content))
    return True


def delete_file(path_str):
    dest = VAULT_PATH / path_str
    if dest.exists():
        dest.unlink()
        log.info("deleted %s", dest)
        # Remove empty parent dirs up to vault root
        try:
            dest.parent.rmdir()
        except OSError:
            pass


# ---------------------------------------------------------------------------
# Full sync (used by cron fallback and on startup)
# ---------------------------------------------------------------------------

def full_sync():
    log.info("starting full sync")
    docs = get_all_plain_docs()
    written = 0
    for doc in docs:
        path = doc.get("path")
        if not path:
            continue
        try:
            content = fetch_content(doc)
            if write_file(path, content):
                written += 1
        except Exception as e:
            log.warning("error syncing %s: %s", path, e)
    log.info("full sync complete: %d/%d files updated", written, len(docs))


# ---------------------------------------------------------------------------
# Live _changes watcher
# ---------------------------------------------------------------------------

def process_change(doc):
    if doc.get("type") != "plain":
        return
    path = doc.get("path")
    if not path:
        return
    if doc.get("_deleted"):
        delete_file(path)
        return
    try:
        content = fetch_content(doc)
        write_file(path, content)
    except Exception as e:
        log.warning("error processing change for %s: %s", path, e)


def watch_changes(since="now"):
    """Stream the _changes feed and process plain-doc updates."""
    params = {
        "feed":       "continuous",
        "heartbeat":  "30000",
        "include_docs": "true",
        "since":      since,
    }
    log.info("watching _changes feed (since=%s)", since)
    last_seq = since
    while True:
        try:
            with requests.get(db_url("/_changes"), params=params,
                              stream=True, timeout=None) as resp:
                resp.raise_for_status()
                for raw_line in resp.iter_lines():
                    if not raw_line:
                        continue  # heartbeat
                    try:
                        event = json.loads(raw_line)
                    except json.JSONDecodeError:
                        continue
                    if "last_seq" in event:
                        last_seq = event["last_seq"]
                        continue
                    seq = event.get("seq")
                    if seq:
                        last_seq = seq
                    doc = event.get("doc")
                    if doc:
                        process_change(doc)
        except requests.exceptions.ConnectionError as e:
            log.warning("connection lost (%s), reconnecting in 5s", e)
            time.sleep(5)
            params["since"] = last_seq
        except Exception as e:
            log.error("unexpected error (%s), reconnecting in 10s", e)
            time.sleep(10)
            params["since"] = last_seq


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--full-sync", action="store_true",
                        help="Run a one-shot full sync and exit (for cron)")
    args = parser.parse_args()

    VAULT_PATH.mkdir(parents=True, exist_ok=True)

    if args.full_sync:
        full_sync()
        return

    # Service mode: full sync on startup, then watch live
    full_sync()
    watch_changes(since="now")


if __name__ == "__main__":
    main()
