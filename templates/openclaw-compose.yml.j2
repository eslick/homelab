services:
  openclaw-gateway:
    build: .
    image: "openclaw-gateway:local"
    container_name: openclaw-gateway
    ports:
      - "127.0.0.1:{{ openclaw_port }}:18789"
      - "127.0.0.1:2099:2099"
      - "127.0.0.1:2100:2100"
    environment:
      ANTHROPIC_API_KEY: "{{ anthropic_api_key | default('') }}"
      OPENAI_API_KEY: "{{ openai_api_key | default('') }}"
      TOGETHER_API_KEY: "{{ together_api_key | default('') }}"
      TZ: "{{ openclaw_tz | default('America/New_York') }}"
      OPENCLAW_ALLOW_INSECURE_PRIVATE_WS: "1"
    volumes:
      - openclaw-data:/home/node/.openclaw
      - /opt/cache/openclaw:/home/node/.cache:rw
      - {{ vault_path }}:/vault:rw
      - {{ secrets_path }}:/secrets:rw
    extra_hosts:
      - "host.docker.internal:host-gateway"
    networks:
      - {{ docker_network }}
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "curl", "-sf", "http://localhost:18789/healthz"]
      interval: 30s
      timeout: 10s
      retries: 3

volumes:
  openclaw-data:

networks:
  {{ docker_network }}:
    external: true
