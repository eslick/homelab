services:
  openclaw-gateway:
    image: "ghcr.io/openclaw/openclaw:{{ openclaw_version | default('latest') }}"
    container_name: openclaw-gateway
    ports:
      - "{{ openclaw_port }}:18789"
    environment:
      OPENCLAW_GATEWAY_TOKEN: "{{ openclaw_gateway_token }}"
      ANTHROPIC_API_KEY: "{{ anthropic_api_key | default('') }}"
      OPENAI_API_KEY: "{{ openai_api_key | default('') }}"
      TZ: "{{ openclaw_tz | default('America/New_York') }}"
      OPENCLAW_ALLOW_INSECURE_PRIVATE_WS: "1"
    volumes:
      - openclaw-data:/home/node/.openclaw
    networks:
      - {{ docker_network }}
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "curl", "-sf", "http://localhost:18789/healthz"]
      interval: 30s
      timeout: 10s
      retries: 3

volumes:
  openclaw-data:

networks:
  {{ docker_network }}:
    external: true
