#!/bin/sh
# Idempotent: register vLLM as a Manifest custom provider and configure tier routing.
# vLLM serves {{ vllm_model_id }} via OpenAI-compatible API on homelab-net at http://vllm:8000/v1.
#
# Tiers updated:
#   simple         → vLLM / {{ vllm_model_id }}   (prefix-cached, concurrent)
#   standard       → vLLM / {{ vllm_model_id }}   (prefix-cached, concurrent)
#   small          → vLLM / {{ vllm_model_id }}   (prefix-cached, concurrent)
#   local-advanced → vLLM / {{ vllm_model_id }}   (prefix-cached, concurrent)
set -e

DB=/home/node/.openclaw/manifest/manifest.db
AGENT_ID=1c4b61d6-242a-4acc-9c5e-9d7605aef10d
MANIFEST_KEY={{ manifest_api_key }}
BASE_URL=http://vllm:8000/v1
MODEL_ID="{{ vllm_served_model_name }}"
CTX={{ vllm_max_model_len }}

MODELS="[{\"model_name\":\"${MODEL_ID}\",\"context_window\":${CTX}}]"

# --- vLLM custom provider (get or create) ---
EXISTING_ID=$(sqlite3 "$DB" \
  "SELECT id FROM custom_providers WHERE agent_id='$AGENT_ID' AND name='vllm' LIMIT 1;")

if [ -z "$EXISTING_ID" ]; then
  PAYLOAD=$(printf '{"name":"vllm","base_url":"%s","apiKey":"vllm","models":%s}' \
    "$BASE_URL" "$MODELS")
  RESULT=$(wget -qO- \
    --post-data "$PAYLOAD" \
    --header "Content-Type: application/json" \
    --header "Authorization: Bearer $MANIFEST_KEY" \
    "http://127.0.0.1:2099/api/v1/routing/open-claw/custom-providers")
  PROVIDER_ID=$(echo "$RESULT" | node -e "let d='';process.stdin.on('data',c=>d+=c).on('end',()=>console.log(JSON.parse(d).id))")
  echo "Created vLLM custom provider: $PROVIDER_ID"
else
  PROVIDER_ID="$EXISTING_ID"
  wget -qO- \
    --method=PUT \
    --body-data "{\"models\":$MODELS}" \
    --header "Content-Type: application/json" \
    --header "Authorization: Bearer $MANIFEST_KEY" \
    "http://127.0.0.1:2099/api/v1/routing/open-claw/custom-providers/$PROVIDER_ID" > /dev/null
  echo "vLLM custom provider exists: $PROVIDER_ID (models synced)"
fi

# --- Register vLLM provider key (vLLM has no auth; dummy key satisfies Manifest) ---
sqlite3 "$DB" "DELETE FROM user_providers WHERE agent_id='$AGENT_ID' AND provider='custom:$PROVIDER_ID';"
wget -qO- \
  --post-data "{\"provider\":\"custom:$PROVIDER_ID\",\"apiKey\":\"vllm\"}" \
  --header "Content-Type: application/json" \
  --header "Authorization: Bearer $MANIFEST_KEY" \
  "http://127.0.0.1:2099/api/v1/routing/open-claw/providers" > /dev/null
echo "Registered vLLM provider key"

# --- Tier assignments ---
CP="custom:${PROVIDER_ID}"
M="${CP}/${MODEL_ID}"

sqlite3 "$DB" "
UPDATE tier_assignments
SET override_model='${M}',
    override_provider='${CP}',
    updated_at=datetime('now')
WHERE agent_id='$AGENT_ID' AND tier IN ('simple', 'standard', 'small', 'local-advanced');
"

# --- Seed cached_models so Manifest's model-discovery doesn't zero out the cache ---
VLLM_MODELS="[{\"id\":\"${MODEL_ID}\"}]"
sqlite3 "$DB" \
  "UPDATE user_providers SET cached_models='$VLLM_MODELS', models_fetched_at=datetime('now') \
   WHERE agent_id='$AGENT_ID' AND provider='custom:$PROVIDER_ID';"
sqlite3 "$DB" \
  "UPDATE custom_providers \
   SET models='[{\"model_name\":\"${MODEL_ID}\",\"context_window\":${CTX}}]', \
       base_url='${BASE_URL}' \
   WHERE agent_id='$AGENT_ID' AND name='vllm';"
echo "Seeded cached_models for vLLM provider ($PROVIDER_ID)"

echo "vLLM tiers configured: simple/standard/small/local-advanced → ${MODEL_ID} (context: ${CTX})"
