# AgentOS two-node BEAM cluster — nginx reverse proxy
# ip_hash ensures LiveView WebSocket connections stay on the node that owns the process.
upstream agentos {
    ip_hash;
    server 127.0.0.1:{{ agentos_beam1_port }};
    server 127.0.0.1:{{ agentos_beam2_port }};
}

server {
    listen {{ tailscale_ip }}:{{ agentos_port }} ssl;
    server_name {{ tailscale_hostname }};

    ssl_certificate {{ cert_dir }}/speedracer.crt;
    ssl_certificate_key {{ cert_dir }}/speedracer.key;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    location / {
        proxy_pass http://agentos;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
    }
}

