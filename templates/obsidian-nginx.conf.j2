# Managed by Ansible — do not edit directly
# See playbooks/nginx.yml

server {
    listen {{ tailscale_ip }}:{{ couchdb_port }} ssl;
    server_name {{ tailscale_hostname }};

    ssl_certificate {{ cert_dir }}/speedracer.crt;
    ssl_certificate_key {{ cert_dir }}/speedracer.key;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    # Vault files can be large; allow generous upload size
    client_max_body_size 512M;

    location / {
        proxy_pass http://127.0.0.1:{{ couchdb_port }};
        proxy_http_version 1.1;

        # Required for CouchDB _changes feed (long-poll / event-stream)
        proxy_buffering off;
        proxy_read_timeout 3600;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
