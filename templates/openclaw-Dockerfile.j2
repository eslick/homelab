FROM ghcr.io/openclaw/openclaw:{{ openclaw_version | default('latest') }}
USER root
RUN npm install -g mcp-google @tobilu/qmd && \
    apt-get update && apt-get install -y --no-install-recommends sqlite3 socat && \
    rm -rf /var/lib/apt/lists/* && \
    # Patch mcp-google: remove allOf from update-event inputSchema.
    # Anthropic's API rejects allOf/oneOf/anyOf at the top level of inputSchema.
    # The conditional required fields (originalStartTime, futureStartDate) are
    # documented in the tool description; removing allOf makes them optional.
    # Uses bracket-counting to reliably find the closing ] of the allOf array.
    node -e " \
      const fs = require('fs'); \
      const f = '/usr/local/lib/node_modules/mcp-google/build/index.js'; \
      let s = fs.readFileSync(f, 'utf8'); \
      const marker = ',\n          // timeZone is technically required for PATCH\n          allOf: ['; \
      const idx = s.indexOf(marker); \
      if (idx === -1) { console.log('mcp-google: allOf marker not found, skipping'); process.exit(0); } \
      let depth = 0, i = idx + marker.length - 1; \
      for (; i < s.length; i++) { if (s[i] === '[') depth++; else if (s[i] === ']') { depth--; if (depth === 0) break; } } \
      s = s.slice(0, idx) + s.slice(i + 1); \
      fs.writeFileSync(f, s); \
      console.log('mcp-google patch applied'); \
    "
COPY openclaw-entrypoint.sh /usr/local/bin/openclaw-entrypoint.sh
RUN chmod +x /usr/local/bin/openclaw-entrypoint.sh
USER node
ENTRYPOINT ["/usr/local/bin/openclaw-entrypoint.sh"]
CMD ["node", "openclaw.mjs", "gateway", "--allow-unconfigured"]
