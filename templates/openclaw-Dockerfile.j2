FROM ghcr.io/openclaw/openclaw:{{ openclaw_version | default('latest') }}
USER root
RUN npm install -g mcp-google @tobilu/qmd && \
    apt-get update && apt-get install -y --no-install-recommends sqlite3 socat && \
    rm -rf /var/lib/apt/lists/* && \
    # Patch mcp-google: remove allOf from update-event inputSchema.
    # Anthropic's API rejects allOf/oneOf/anyOf at the top level of inputSchema.
    # The conditional required fields (originalStartTime, futureStartDate) are
    # documented in the tool description; removing allOf makes them optional.
    # Uses bracket-counting to reliably find the closing ] of the allOf array.
    node -e " \
      const fs = require('fs'); \
      const f = '/usr/local/lib/node_modules/mcp-google/build/index.js'; \
      let s = fs.readFileSync(f, 'utf8'); \
      const marker = ',\n          // timeZone is technically required for PATCH\n          allOf: ['; \
      const idx = s.indexOf(marker); \
      if (idx === -1) { console.log('mcp-google: allOf marker not found, skipping'); process.exit(0); } \
      let depth = 0, i = idx + marker.length - 1; \
      for (; i < s.length; i++) { if (s[i] === '[') depth++; else if (s[i] === ']') { depth--; if (depth === 0) break; } } \
      s = s.slice(0, idx) + s.slice(i + 1); \
      fs.writeFileSync(f, s); \
      console.log('mcp-google allOf patch applied'); \
    " && \
    # Patch mcp-google: strip HTML email bodies, truncate plain text to 8000 chars.
    # HTML newsletters (e.g. MIT bulletin) can be 148k+ bytes (~37k tokens) which
    # overflows the 32k vLLM context window. Plain text is sufficient for reading.
    node -e " \
      const fs = require('fs'); \
      const f = '/usr/local/lib/node_modules/mcp-google/build/index.js'; \
      let s = fs.readFileSync(f, 'utf8'); \
      let p = s; \
      p = p.replace( \
        '} else if (payload.mimeType === \"text/html\") {\n        result.html = decoded;\n      }', \
        '} else if (payload.mimeType === \"text/html\") {\n        /* MCP_GOOGLE_BODY_PATCH: skip html */\n      }' \
      ); \
      p = p.replace( \
        '} else if (part.mimeType === \"text/html\" && part.body?.data) {\n          result.html = Buffer.from(part.body.data, \"base64\").toString(\"utf-8\");\n        }', \
        '} else if (part.mimeType === \"text/html\" && part.body?.data) {\n          /* MCP_GOOGLE_BODY_PATCH: skip html */\n        }' \
      ); \
      p = p.replace( \
        'if (nestedBody.text) result.text = nestedBody.text;\n          if (nestedBody.html) result.html = nestedBody.html;', \
        'if (nestedBody.text) result.text = nestedBody.text; /* MCP_GOOGLE_BODY_PATCH */' \
      ); \
      p = p.replace( \
        'body: this.extractBody(message.payload),', \
        'body: (() => { const b = this.extractBody(message.payload); const MAX = 8000; if (b.text && b.text.length > MAX) { b.text = b.text.slice(0, MAX) + \"...[truncated, \" + b.text.length + \" chars total]\"; } return b; /* MCP_GOOGLE_BODY_PATCH */ })(),' \
      ); \
      if (p !== s) { fs.writeFileSync(f, p); console.log('mcp-google body patch applied'); } \
      else { console.log('mcp-google body patch: no changes (already patched?)'); } \
    "
COPY openclaw-entrypoint.sh /usr/local/bin/openclaw-entrypoint.sh
RUN chmod +x /usr/local/bin/openclaw-entrypoint.sh
USER node
ENTRYPOINT ["/usr/local/bin/openclaw-entrypoint.sh"]
CMD ["node", "openclaw.mjs", "gateway", "--allow-unconfigured"]
